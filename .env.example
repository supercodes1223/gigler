# ── Twilio ──
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
GIGLER_NUMBER=
TWILIO_CONVERSATIONS_SERVICE_SID=

# ── Google / Gemini ──
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# ── AI Image/Video Generation ──
OPENAI_API_KEY=

# ── SES (Email) ──
SES_FROM_EMAIL=notifications@gigler.ai
SES_FROM_NAME=Gigler

# ── Stripe ──
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# ── Frontend (NEXT_PUBLIC_ vars inlined at build time) ──
NEXT_PUBLIC_SITE_URL=https://gigler.ai
NEXT_PUBLIC_BRAND=gigler
NEXT_PUBLIC_IMG_CDN=

# ── S3 / CloudFront ──
S3_BUCKET_NAME=
CLOUDFRONT_DISTRIBUTION_ID=
CLOUDFRONT_DOMAIN=

# ── Amplify (set after connecting repo to Amplify Console) ──
AMPLIFY_APP_ID=

# ── AppSync (server-side gig creation from the web; SSR has no IAM, uses API key) ──
APPSYNC_URL=
APPSYNC_API_KEY=

# ── Web gig fulfillment ──
# Public Function URL of the gigler-gig-processor Lambda (printed at deploy in
# amplify/backend.ts). Lets /api/gig/create kick the processor without IAM so
# web-created gigs actually start and the user gets their first text.
GIG_PROCESSOR_FUNCTION_URL=
# Optional: shared secret required on web-gig POSTs. Set the SAME value in both
# Amplify Hosting (Next) env and the gig-processor Lambda env to lock down the
# public Function URL against abuse.
WEB_GIG_SHARED_SECRET=
# Alternative to the Function URL: direct Lambda invoke (needs the SSR role to
# have lambda:InvokeFunction on the processor). Usually leave blank.
GIG_PROCESSOR_FUNCTION_NAME=
