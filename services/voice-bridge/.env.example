# Gemini Live
GOOGLE_API_KEY=
GEMINI_MODEL=models/gemini-3.1-flash-live-preview
GEMINI_VOICE=Puck

# Twilio
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_MESSAGING_SERVICE_SID=
GIGLER_NUMBER=+16508351235

# AWS (cross-cloud IAM user scoped to the Gigler tables + gig-processor invoke)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-2

# Gigler DynamoDB tables (Amplify-generated names)
USER_TABLE_NAME=
GIG_TABLE_NAME=
MESSAGE_TABLE_NAME=
GIG_PARTICIPANT_TABLE_NAME=
GIG_PROCESSOR_FUNCTION_NAME=

# Bridge
BRIDGE_PUBLIC_HOST=voice.gigler.ai
BRIDGE_HOST=0.0.0.0
BRIDGE_PORT=8765
MAX_CALL_SECONDS=300
MAX_CONCURRENT_CALLS=5

# Logging
ENABLE_GCL=1
GCP_PROJECT_ID=
GCP_LOG_NAME=gigler-voice-bridge
