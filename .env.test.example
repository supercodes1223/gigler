# Gigler E2E Test Configuration
# Copy to .env.test and fill in after deployment
#
# Usage:
#   cp .env.test.example .env.test
#   # Edit .env.test with your deployed values
#   ./scripts/test-e2e.sh smoke

# ── Required ──────────────────────────────────────────────────────────────────

# Lambda Function URL for gigler-inbound-sms (from Amplify deployment output)
LAMBDA_URL=https://xxxxxxxxxx.lambda-url.us-east-2.on.aws/

# Lambda Function URL for gigler-gig-processor (Conversations webhook endpoint)
GIG_PROCESSOR_URL=https://xxxxxxxxxx.lambda-url.us-east-2.on.aws/

# ── AWS ───────────────────────────────────────────────────────────────────────

AWS_REGION=us-east-2

# ── Test Data ─────────────────────────────────────────────────────────────────

# Phone number to use for test SMS (use a real number you control for SMS verification)
TEST_PHONE=+15551234567

# Gigler's Twilio phone number
TEST_GIGLER_NUMBER=+16508351235

# Participant phone for group MMS / routing tests
TEST_PARTICIPANT_PHONE=+14154049816

# Participant display name
TEST_PARTICIPANT_NAME=Sarah

# ── Twilio (for test-live-sms.sh real SMS tests) ─────────────────────────────

# TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# TWILIO_MESSAGING_SERVICE_SID=MGxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Optional: Pre-set IDs for direct Lambda invocation tests ──────────────────
# If not set, the SMS onboarding test will discover them automatically.

# TEST_USER_ID=usr_1234567890_abc123
# TEST_GIG_ID=gig_1234567890_xyz789
# TEST_CONVERSATION_SID=CHxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Optional: Override auto-discovered DynamoDB table names ───────────────────
# The test script auto-discovers tables from your AWS account.
# Set these only if auto-discovery picks the wrong table.

# USER_TABLE=
# GIG_TABLE=
# GIG_PARTICIPANT_TABLE=
# MESSAGE_TABLE=
# MEDIA_TABLE=
# DELIVERABLE_TABLE=
# REMINDER_TABLE=
# THIRD_PARTY_TABLE=
# USER_INTEGRATION_TABLE=

# ── Optional: Override auto-discovered Lambda function names ──────────────────

# INBOUND_SMS_FN=
# GIG_PROCESSOR_FN=
# REMINDER_FN=
# MEDIA_FN=
# DELIVERABLE_FN=
# VOICE_FN=
# EMAIL_FN=
# THIRD_PARTY_FN=
