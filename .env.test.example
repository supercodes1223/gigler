# Gigler E2E Test Configuration
# Copy to .env.test and fill in after deployment
#
# Usage:
#   cp .env.test.example .env.test
#   # Edit .env.test with your deployed values
#   ./scripts/test-e2e.sh smoke

# ── Required ──────────────────────────────────────────────────────────────────

# Lambda Function URL for gigler-inbound-sms (from Amplify deployment output)
LAMBDA_URL=https://xxxxxxxxxx.lambda-url.us-east-1.on.aws/

# ── AWS ───────────────────────────────────────────────────────────────────────

AWS_REGION=us-east-1

# ── Test Data ─────────────────────────────────────────────────────────────────

# Phone number to use for test SMS (use a real number you control for SMS verification)
TEST_PHONE=+15551234567

# Gigler's Twilio phone number
TEST_GIGLER_NUMBER=+15559876543

# ── Optional: Pre-set IDs for direct Lambda invocation tests ──────────────────
# If not set, the SMS onboarding test will discover them automatically.

# TEST_USER_ID=usr_1234567890_abc123
# TEST_GIG_ID=gig_1234567890_xyz789

# ── Optional: Override auto-discovered DynamoDB table names ───────────────────
# The test script auto-discovers tables from your AWS account.
# Set these only if auto-discovery picks the wrong table.

# USER_TABLE=
# GIG_TABLE=
# GIG_PARTICIPANT_TABLE=
# MESSAGE_TABLE=
# MEDIA_TABLE=
# DELIVERABLE_TABLE=
# REMINDER_TABLE=
# THIRD_PARTY_TABLE=
# USER_INTEGRATION_TABLE=

# ── Optional: Override auto-discovered Lambda function names ──────────────────

# INBOUND_SMS_FN=
# GIG_PROCESSOR_FN=
# REMINDER_FN=
# MEDIA_FN=
# DELIVERABLE_FN=
# VOICE_FN=
# EMAIL_FN=
# THIRD_PARTY_FN=
